"""
丰碑自动广播与同步 —— 去重、增量同步、全网收敛

模块职责：
  - 新丰碑自动广播到所有已知节点
  - 接收丰碑时验签 + 存储 + 继续广播
  - 去重机制（丰碑ID + 签名）
  - 增量同步（since timestamp）
  - 全网收敛保证
"""

import json
import hashlib
import time
from datetime import datetime
from typing import Any, Dict, List, Optional, Set, Tuple

import requests

from config import API_HOST, API_PORT
from core.p2p_network import (
    P2PIdentity,
